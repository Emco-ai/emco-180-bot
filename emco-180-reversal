<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>EMCO 180 Precision Bot</title>
    <style>
        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
        }

        :root {
            --bg-primary: #0a0e17;
            --bg-secondary: #111827;
            --bg-tertiary: #1f2937;
            --accent-primary: #00d4ff;
            --accent-secondary: #00ff88;
            --accent-danger: #ff4757;
            --accent-warning: #ffa502;
            --text-primary: #f1f5f9;
            --text-secondary: #94a3b8;
            --border-color: #2d3748;
        }

        body {
            font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;
            background: var(--bg-primary);
            color: var(--text-primary);
            min-height: 100vh;
            overflow-x: hidden;
        }

        .container {
            max-width: 1400px;
            margin: 0 auto;
            padding: 20px;
        }

        header {
            text-align: center;
            padding: 30px 0;
            border-bottom: 2px solid var(--accent-primary);
            margin-bottom: 30px;
            background: linear-gradient(135deg, var(--bg-secondary) 0%, var(--bg-primary) 100%);
        }

        h1 {
            font-size: 2.5rem;
            background: linear-gradient(90deg, var(--accent-primary), var(--accent-secondary));
            -webkit-background-clip: text;
            -webkit-text-fill-color: transparent;
            margin-bottom: 10px;
            letter-spacing: 2px;
        }

        .subtitle {
            color: var(--text-secondary);
            font-size: 1.1rem;
        }

        .grid {
            display: grid;
            grid-template-columns: repeat(auto-fit, minmax(350px, 1fr));
            gap: 20px;
            margin-bottom: 20px;
        }

        .panel {
            background: var(--bg-secondary);
            border-radius: 12px;
            padding: 20px;
            border: 1px solid var(--border-color);
            box-shadow: 0 4px 6px rgba(0, 0, 0, 0.3);
        }

        .panel-header {
            display: flex;
            align-items: center;
            justify-content: space-between;
            margin-bottom: 15px;
            padding-bottom: 10px;
            border-bottom: 1px solid var(--border-color);
        }

        .panel-title {
            font-size: 1.1rem;
            color: var(--accent-primary);
            font-weight: 600;
            display: flex;
            align-items: center;
            gap: 8px;
        }

        .status-indicator {
            width: 12px;
            height: 12px;
            border-radius: 50%;
            background: var(--accent-danger);
            box-shadow: 0 0 10px currentColor;
            transition: all 0.3s ease;
        }

        .status-indicator.connected {
            background: var(--accent-secondary);
        }

        .status-indicator.connecting {
            background: var(--accent-warning);
            animation: pulse 1s infinite;
        }

        @keyframes pulse {
            0%, 100% { opacity: 1; }
            50% { opacity: 0.5; }
        }

        .form-group {
            margin-bottom: 15px;
        }

        label {
            display: block;
            margin-bottom: 5px;
            color: var(--text-secondary);
            font-size: 0.9rem;
            font-weight: 500;
        }

        input, select {
            width: 100%;
            padding: 10px 12px;
            background: var(--bg-tertiary);
            border: 1px solid var(--border-color);
            border-radius: 6px;
            color: var(--text-primary);
            font-size: 0.95rem;
            transition: all 0.3s ease;
        }

        input:focus, select:focus {
            outline: none;
            border-color: var(--accent-primary);
            box-shadow: 0 0 0 3px rgba(0, 212, 255, 0.1);
        }

        button {
            padding: 12px 24px;
            border: none;
            border-radius: 6px;
            font-size: 0.95rem;
            font-weight: 600;
            cursor: pointer;
            transition: all 0.3s ease;
            text-transform: uppercase;
            letter-spacing: 0.5px;
        }

        .btn-primary {
            background: linear-gradient(135deg, var(--accent-primary), #0099cc);
            color: white;
        }

        .btn-primary:hover:not(:disabled) {
            transform: translateY(-2px);
            box-shadow: 0 4px 12px rgba(0, 212, 255, 0.4);
        }

        .btn-success {
            background: linear-gradient(135deg, var(--accent-secondary), #00cc6a);
            color: white;
        }

        .btn-success:hover:not(:disabled) {
            transform: translateY(-2px);
            box-shadow: 0 4px 12px rgba(0, 255, 136, 0.4);
        }

        .btn-danger {
            background: linear-gradient(135deg, var(--accent-danger), #cc3344);
            color: white;
        }

        .btn-danger:hover:not(:disabled) {
            transform: translateY(-2px);
            box-shadow: 0 4px 12px rgba(255, 71, 87, 0.4);
        }

        button:disabled {
            opacity: 0.6;
            cursor: not-allowed;
        }

        .stats-grid {
            display: grid;
            grid-template-columns: repeat(2, 1fr);
            gap: 15px;
        }

        .stat-card {
            background: var(--bg-tertiary);
            padding: 15px;
            border-radius: 8px;
            text-align: center;
            border: 1px solid var(--border-color);
        }

        .stat-label {
            font-size: 0.8rem;
            color: var(--text-secondary);
            margin-bottom: 5px;
            text-transform: uppercase;
            letter-spacing: 0.5px;
        }

        .stat-value {
            font-size: 1.4rem;
            font-weight: 700;
            color: var(--text-primary);
        }

        .stat-value.positive {
            color: var(--accent-secondary);
        }

        .stat-value.negative {
            color: var(--accent-danger);
        }

        .confidence-meter {
            width: 100%;
            height: 30px;
            background: var(--bg-tertiary);
            border-radius: 15px;
            overflow: hidden;
            margin-top: 10px;
            position: relative;
        }

        .confidence-fill {
            height: 100%;
            background: linear-gradient(90deg, var(--accent-danger), var(--accent-warning), var(--accent-secondary));
            transition: width 0.5s ease;
            display: flex;
            align-items: center;
            justify-content: center;
            font-weight: 700;
            font-size: 0.9rem;
        }

        .signal-display {
            padding: 20px;
            border-radius: 8px;
            text-align: center;
            margin-top: 15px;
            border: 2px solid transparent;
            transition: all 0.3s ease;
        }

        .signal-display.bull {
            background: rgba(0, 255, 136, 0.1);
            border-color: var(--accent-secondary);
        }

        .signal-display.bear {
            background: rgba(255, 71, 87, 0.1);
            border-color: var(--accent-danger);
        }

        .signal-display.neutral {
            background: var(--bg-tertiary);
            border-color: var(--border-color);
        }

        .signal-direction {
            font-size: 1.5rem;
            font-weight: 700;
            margin-bottom: 10px;
        }

        .bull { color: var(--accent-secondary); }
        .bear { color: var(--accent-danger); }

        .log-container {
            max-height: 300px;
            overflow-y: auto;
            background: var(--bg-tertiary);
            border-radius: 8px;
            padding: 10px;
            font-family: 'Courier New', monospace;
            font-size: 0.85rem;
        }

        .log-entry {
            padding: 6px 8px;
            margin-bottom: 4px;
            border-radius: 4px;
            border-left: 3px solid transparent;
        }

        .log-entry.info {
            border-left-color: var(--accent-primary);
            background: rgba(0, 212, 255, 0.05);
        }

        .log-entry.success {
            border-left-color: var(--accent-secondary);
            background: rgba(0, 255, 136, 0.05);
        }

        .log-entry.error {
            border-left-color: var(--accent-danger);
            background: rgba(255, 71, 87, 0.05);
        }

        .log-entry.warning {
            border-left-color: var(--accent-warning);
            background: rgba(255, 165, 2, 0.05);
        }

        .log-time {
            color: var(--accent-primary);
            margin-right: 8px;
        }

        .control-buttons {
            display: flex;
            gap: 10px;
            margin-top: 15px;
        }

        .control-buttons button {
            flex: 1;
        }

        .market-quality {
            display: flex;
            gap: 10px;
            flex-wrap: wrap;
            margin-top: 10px;
        }

        .quality-badge {
            padding: 5px 10px;
            border-radius: 20px;
            font-size: 0.8rem;
            background: var(--bg-tertiary);
            border: 1px solid var(--border-color);
        }

        .quality-badge.good {
            border-color: var(--accent-secondary);
            color: var(--accent-secondary);
        }

        .quality-badge.bad {
            border-color: var(--accent-danger);
            color: var(--accent-danger);
        }

        .checkbox-group {
            display: flex;
            align-items: center;
            gap: 10px;
            margin-top: 10px;
        }

        input[type="checkbox"] {
            width: auto;
            cursor: pointer;
        }

        .trades-table {
            width: 100%;
            border-collapse: collapse;
            font-size: 0.85rem;
        }

        .trades-table th,
        .trades-table td {
            padding: 8px;
            text-align: left;
            border-bottom: 1px solid var(--border-color);
        }

        .trades-table th {
            color: var(--accent-primary);
            font-weight: 600;
        }

        .trades-table tr:hover {
            background: var(--bg-tertiary);
        }

        .win { color: var(--accent-secondary); }
        .loss { color: var(--accent-danger); }

        .progress-bar {
            width: 100%;
            height: 8px;
            background: var(--bg-tertiary);
            border-radius: 4px;
            overflow: hidden;
            margin-top: 5px;
        }

        .progress-fill {
            height: 100%;
            background: var(--accent-primary);
            transition: width 0.3s ease;
        }

        @media (max-width: 768px) {
            .grid {
                grid-template-columns: 1fr;
            }
            h1 { font-size: 1.8rem; }
        }
    </style>
</head>
<body>
    <div class="container">
        <header>
            <h1>EMCO 180 PRECISION BOT</h1>
            <p class="subtitle">Advanced Reversal Pattern Detection & Automated Trading</p>
        </header>

        <div class="grid">
            <!-- Connection Panel -->
            <div class="panel">
                <div class="panel-header">
                    <span class="panel-title">🔌 Connection</span>
                    <div class="status-indicator" id="connectionStatus"></div>
                </div>
                <div class="form-group">
                    <label>API Token</label>
                    <input type="password" id="apiToken" placeholder="Enter your Deriv API token">
                </div>
                <button class="btn-primary" id="connectBtn" onclick="connectionModule.connect()">Connect</button>
                <div class="stats-grid" style="margin-top: 15px;">
                    <div class="stat-card">
                        <div class="stat-label">Balance</div>
                        <div class="stat-value" id="balanceDisplay">--</div>
                    </div>
                    <div class="stat-card">
                        <div class="stat-label">Currency</div>
                        <div class="stat-value" id="currencyDisplay">--</div>
                    </div>
                </div>
            </div>

            <!-- Market Configuration -->
            <div class="panel">
                <div class="panel-header">
                    <span class="panel-title">📊 Market Setup</span>
                </div>
                <div class="form-group">
                    <label>Market Index</label>
                    <select id="marketSelect">
                        <option value="R_10">Volatility 10 Index</option>
                        <option value="R_25">Volatility 25 Index</option>
                        <option value="R_50">Volatility 50 Index</option>
                        <option value="R_75">Volatility 75 Index</option>
                        <option value="R_100">Volatility 100 Index</option>
                    </select>
                </div>
                <div class="form-group">
                    <label>Candle Timeframe</label>
                    <select id="timeframeSelect">
                        <option value="60">1 Minute</option>
                        <option value="300">5 Minutes</option>
                    </select>
                </div>
                <div class="market-quality" id="marketQuality">
                    <span class="quality-badge">Quality tracking active</span>
                </div>
            </div>

            <!-- Risk Management -->
            <div class="panel">
                <div class="panel-header">
                    <span class="panel-title">🛡️ Risk Management</span>
                </div>
                <div class="form-group">
                    <label>Risk Per Trade (%)</label>
                    <input type="number" id="riskPercent" value="2" min="0.1" max="10" step="0.1">
                </div>
                <div class="form-group">
                    <label>Daily Profit Target (%)</label>
                    <input type="number" id="profitTarget" value="10" min="1" max="50" step="1">
                </div>
                <div class="form-group">
                    <label>Daily Loss Limit (%)</label>
                    <input type="number" id="lossLimit" value="6" min="1" max="20" step="1">
                </div>
                <div class="stats-grid">
                    <div class="stat-card">
                        <div class="stat-label">Daily P/L</div>
                        <div class="stat-value" id="dailyPL">0.00</div>
                    </div>
                    <div class="stat-card">
                        <div class="stat-label">Progress</div>
                        <div class="progress-bar">
                            <div class="progress-fill" id="dailyProgress" style="width: 0%"></div>
                        </div>
                    </div>
                </div>
            </div>

            <!-- Bot Controls -->
            <div class="panel">
                <div class="panel-header">
                    <span class="panel-title">🤖 Bot Controls</span>
                </div>
                <div class="control-buttons">
                    <button class="btn-success" id="startBtn" onclick="botController.startTrading()" disabled>Start Trading</button>
                    <button class="btn-danger" id="stopBtn" onclick="botController.stopTrading()" disabled>Stop Trading</button>
                </div>
                <div class="checkbox-group">
                    <input type="checkbox" id="simulationMode" checked>
                    <label for="simulationMode" style="margin: 0;">Simulation Mode (No real trades)</label>
                </div>
                <div class="signal-display neutral" id="signalDisplay">
                    <div class="signal-direction" id="signalDirection">WAITING FOR SIGNAL</div>
                    <div id="signalDetails">Bot ready to analyze market</div>
                    <div class="confidence-meter">
                        <div class="confidence-fill" id="confidenceFill" style="width: 0%">0%</div>
                    </div>
                </div>
            </div>

            <!-- Statistics -->
            <div class="panel">
                <div class="panel-header">
                    <span class="panel-title">📈 Performance Stats</span>
                </div>
                <div class="stats-grid">
                    <div class="stat-card">
                        <div class="stat-label">Total Trades</div>
                        <div class="stat-value" id="totalTrades">0</div>
                    </div>
                    <div class="stat-card">
                        <div class="stat-label">Win Rate</div>
                        <div class="stat-value" id="winRate">0%</div>
                    </div>
                    <div class="stat-card">
                        <div class="stat-label">Wins</div>
                        <div class="stat-value positive" id="totalWins">0</div>
                    </div>
                    <div class="stat-card">
                        <div class="stat-label">Losses</div>
                        <div class="stat-value negative" id="totalLosses">0</div>
                    </div>
                </div>
                <div class="stat-card" style="margin-top: 15px;">
                    <div class="stat-label">Net Profit</div>
                    <div class="stat-value" id="netProfit">0.00</div>
                </div>
            </div>

            <!-- Recent Trades -->
            <div class="panel">
                <div class="panel-header">
                    <span class="panel-title">💼 Recent Trades</span>
                </div>
                <div style="max-height: 200px; overflow-y: auto;">
                    <table class="trades-table">
                        <thead>
                            <tr>
                                <th>Time</th>
                                <th>Dir</th>
                                <th>Result</th>
                                <th>P/L</th>
                            </tr>
                        </thead>
                        <tbody id="tradesTableBody">
                            <tr><td colspan="4" style="text-align: center; color: var(--text-secondary);">No trades yet</td></tr>
                        </tbody>
                    </table>
                </div>
            </div>
        </div>

        <!-- Activity Log -->
        <div class="panel">
            <div class="panel-header">
                <span class="panel-title">📝 Activity Log</span>
                <button class="btn-primary" style="padding: 6px 12px; font-size: 0.8rem;" onclick="logger.clear()">Clear</button>
            </div>
            <div class="log-container" id="activityLog"></div>
        </div>
    </div>

    <script>
        /**
         * EMCO 180 PRECISION BOT
         * Advanced Deriv Trading Bot with Reversal Pattern Detection
         * 
         * Architecture:
         * 1. Connection Module - WebSocket management
         * 2. Market Data Module - Tick/candle data handling
         * 3. Candle Builder - Aggregates ticks into candles
         * 4. EMA Calculator - Trend analysis
         * 5. Pattern Detection - EMCO 180 pattern recognition
         * 6. Confidence Scoring - Signal quality assessment
         * 7. Trade Execution - Order management
         * 8. Risk Manager - Position sizing and limits
         * 9. Dashboard Updater - UI updates
         * 10. Logger - Activity logging
         */

        // ==================== CONFIGURATION ====================
        const CONFIG = {
            APP_ID: 1089,
            WS_URL: 'wss://ws.derivws.com/websockets/v3',
            MAX_CANDLES: 200,
            MIN_CONFIDENCE: 70,
            MAX_TRADES_PER_HOUR: 2,
            MIN_CANDLES_BETWEEN_TRADES: 5,
            PAUSE_AFTER_CONSECUTIVE_LOSSES: 3,
            RESUME_AFTER_CANDLES: 10,
            ADAPTIVE_LEARNING_RATE: 0.1,
            MARKET_SYMBOLS: {
                'R_10': 'Volatility 10 Index',
                'R_25': 'Volatility 25 Index',
                'R_50': 'Volatility 50 Index',
                'R_75': 'Volatility 75 Index',
                'R_100': 'Volatility 100 Index'
            }
        };

        // ==================== STATE MANAGEMENT ====================
        const state = {
            ws: null,
            isConnected: false,
            isTrading: false,
            accountInfo: null,
            balance: 0,
            currency: 'USD',
            candles: [],
            currentCandle: null,
            lastTick: null,
            ema20: null,
            pendingProposal: null,
            openContracts: [],
            tradeHistory: [],
            dailyStats: {
                startBalance: 0,
                currentProfit: 0,
                tradesTaken: 0,
                lastTradeTime: null,
                candlesSinceLastTrade: 0,
                consecutiveLosses: 0,
                isPaused: false,
                pauseEndCandle: 0
            },
            marketQuality: {},
            adaptiveWeights: {
                elephant: 20,
                engulf: 20,
                trend: 20,
                exhaustion: 15,
                strength: 15,
                ema: 10
            },
            signalHistory: [],
            simulationMode: true
        };

        // ==================== LOGGER MODULE ====================
        const logger = {
            log(message, type = 'info') {
                const timestamp = new Date().toLocaleTimeString();
                const logContainer = document.getElementById('activityLog');
                const entry = document.createElement('div');
                entry.className = `log-entry ${type}`;
                entry.innerHTML = `<span class="log-time">[${timestamp}]</span>${message}`;
                logContainer.insertBefore(entry, logContainer.firstChild);
                
                // Keep only last 100 entries
                while (logContainer.children.length > 100) {
                    logContainer.removeChild(logContainer.lastChild);
                }
                
                console.log(`[${type.toUpperCase()}] ${message}`);
            },

            clear() {
                document.getElementById('activityLog').innerHTML = '';
                this.log('Log cleared', 'info');
            }
        };

        // ==================== CONNECTION MODULE ====================
        const connectionModule = {
            connect() {
                const token = document.getElementById('apiToken').value.trim();
                if (!token) {
                    logger.log('Please enter API token', 'error');
                    return;
                }

                this.updateStatus('connecting');
                logger.log('Connecting to Deriv...', 'info');

                try {
                    state.ws = new WebSocket(`${CONFIG.WS_URL}?app_id=${CONFIG.APP_ID}`);

                    state.ws.onopen = () => {
                        logger.log('WebSocket connected', 'success');
                        this.authenticate(token);
                    };

                    state.ws.onmessage = (event) => {
                        const data = JSON.parse(event.data);
                        this.handleMessage(data);
                    };

                    state.ws.onerror = (error) => {
                        logger.log('WebSocket error occurred', 'error');
                        this.updateStatus('disconnected');
                        botController.stopTrading();
                    };

                    state.ws.onclose = () => {
                        logger.log('WebSocket disconnected', 'warning');
                        this.updateStatus('disconnected');
                        state.isConnected = false;
                        botController.stopTrading();
                    };

                } catch (error) {
                    logger.log(`Connection failed: ${error.message}`, 'error');
                    this.updateStatus('disconnected');
                }
            },

            authenticate(token) {
                const authReq = {
                    authorize: token,
                    req_id: 1
                };
                this.send(authReq);
            },

            send(message) {
                if (state.ws && state.ws.readyState === WebSocket.OPEN) {
                    state.ws.send(JSON.stringify(message));
                } else {
                    logger.log('WebSocket not ready', 'error');
                }
            },

            handleMessage(data) {
                // Handle authentication response
                if (data.authorize) {
                    state.accountInfo = data.authorize;
                    state.balance = data.authorize.balance;
                    state.currency = data.authorize.currency;
                    state.isConnected = true;
                    state.dailyStats.startBalance = data.authorize.balance;
                    
                    this.updateStatus('connected');
                    dashboardUpdater.updateAccountInfo();
                    logger.log(`Authenticated: ${data.authorize.fullname}`, 'success');
                    
                    // Enable start button
                    document.getElementById('startBtn').disabled = false;
                    
                    // Subscribe to balance updates
                    this.send({ balance: 1, subscribe: 1 });
                }

                // Handle balance updates
                if (data.balance) {
                    state.balance = data.balance.balance;
                    dashboardUpdater.updateBalance();
                }

                // Handle tick data
                if (data.tick) {
                    marketDataModule.handleTick(data.tick);
                }

                // Handle proposal
                if (data.proposal) {
                    tradeExecutionModule.handleProposal(data.proposal);
                }

                // Handle buy confirmation
                if (data.buy) {
                    tradeExecutionModule.handleBuyConfirmation(data.buy);
                }

                // Handle contract updates
                if (data.proposal_open_contract) {
                    tradeExecutionModule.handleContractUpdate(data.proposal_open_contract);
                }

                // Handle errors
                if (data.error) {
                    logger.log(`API Error: ${data.error.message}`, 'error');
                    if (state.isTrading) {
                        botController.stopTrading();
                    }
                }
            },

            updateStatus(status) {
                const indicator = document.getElementById('connectionStatus');
                indicator.className = 'status-indicator ' + status;
                
                const btn = document.getElementById('connectBtn');
                if (status === 'connected') {
                    btn.textContent = 'Connected';
                    btn.disabled = true;
                } else if (status === 'connecting') {
                    btn.textContent = 'Connecting...';
                    btn.disabled = true;
                } else {
                    btn.textContent = 'Connect';
                    btn.disabled = false;
                }
            },

            disconnect() {
                if (state.ws) {
                    state.ws.close();
                }
            }
        };

        // ==================== MARKET DATA MODULE ====================
        const marketDataModule = {
            subscribeToMarket() {
                const symbol = document.getElementById('marketSelect').value;
                
                // Unsubscribe from previous
                this.send({ forget_all: 'ticks' });
                
                // Subscribe to new market
                this.send({
                    ticks: symbol,
                    subscribe: 1
                });
                
                logger.log(`Subscribed to ${CONFIG.MARKET_SYMBOLS[symbol]}`, 'info');
                
                // Initialize market quality tracking if not exists
                if (!state.marketQuality[symbol]) {
                    state.marketQuality[symbol] = { trades: 0, wins: 0, winRate: 50 };
                }
            },

            send(message) {
                connectionModule.send(message);
            },

            handleTick(tick) {
                state.lastTick = tick;
                candleBuilder.processTick(tick);
            },

            changeMarket() {
                if (state.isTrading) {
                    logger.log('Stop trading before changing market', 'warning');
                    return;
                }
                state.candles = [];
                state.currentCandle = null;
                this.subscribeToMarket();
            }
        };

        // ==================== CANDLE BUILDER MODULE ====================
        const candleBuilder = {
            processTick(tick) {
                const timeframe = parseInt(document.getElementById('timeframeSelect').value);
                const tickTime = tick.epoch;
                const tickPrice = tick.quote;
                
                // Calculate candle timestamp (floor to timeframe)
                const candleTime = Math.floor(tickTime / timeframe) * timeframe;
                
                if (!state.currentCandle || state.currentCandle.time !== candleTime) {
                    // New candle started
                    if (state.currentCandle) {
                        this.finalizeCandle();
                    }
                    
                    state.currentCandle = {
                        time: candleTime,
                        open: tickPrice,
                        high: tickPrice,
                        low: tickPrice,
                        close: tickPrice,
                        ticks: 1
                    };
                } else {
                    // Update current candle
                    state.currentCandle.high = Math.max(state.currentCandle.high, tickPrice);
                    state.currentCandle.low = Math.min(state.currentCandle.low, tickPrice);
                    state.currentCandle.close = tickPrice;
                    state.currentCandle.ticks++;
                }
                
                // Update EMA in real-time for trend analysis
                if (state.candles.length >= 20) {
                    emaCalculator.calculate();
                }
            },

            finalizeCandle() {
                if (!state.currentCandle) return;
                
                const candle = {
                    ...state.currentCandle,
                    bodySize: Math.abs(state.currentCandle.close - state.currentCandle.open),
                    direction: state.currentCandle.close > state.currentCandle.open ? 'bullish' : 
                               state.currentCandle.close < state.currentCandle.open ? 'bearish' : 'neutral',
                    upperWick: state.currentCandle.high - Math.max(state.currentCandle.open, state.currentCandle.close),
                    lowerWick: Math.min(state.currentCandle.open, state.currentCandle.close) - state.currentCandle.low
                };
                
                state.candles.push(candle);
                
                // Keep only MAX_CANDLES
                if (state.candles.length > CONFIG.MAX_CANDLES) {
                    state.candles.shift();
                }
                
                // Increment candles since last trade
                state.dailyStats.candlesSinceLastTrade++;
                
                // Check if pause should end
                if (state.dailyStats.isPaused) {
                    if (state.dailyStats.candlesSinceLastTrade >= state.dailyStats.pauseEndCandle) {
                        state.dailyStats.isPaused = false;
                        logger.log('Trading pause ended - resuming operations', 'info');
                    }
                }
                
                // Process completed candle for signals
                if (state.isTrading && !state.dailyStats.isPaused) {
                    patternDetectionEngine.analyze(candle);
                }
                
                // Update dashboard
                dashboardUpdater.updateCandleInfo(candle);
            },

            getAverageBody(periods = 10) {
                if (state.candles.length < periods) return 0;
                const recent = state.candles.slice(-periods);
                const sum = recent.reduce((acc, c) => acc + c.bodySize, 0);
                return sum / periods;
            },

            getLastCandles(count) {
                return state.candles.slice(-count);
            }
        };

        // ==================== EMA CALCULATOR MODULE ====================
        const emaCalculator = {
            calculate() {
                if (state.candles.length < 20) return null;
                
                const closes = state.candles.map(c => c.close);
                const multiplier = 2 / (20 + 1);
                
                let ema = closes[0];
                for (let i = 1; i < closes.length; i++) {
                    ema = (closes[i] - ema) * multiplier + ema;
                }
                
                state.ema20 = ema;
                return ema;
            },

            isAboveEMA(price) {
                return state.ema20 && price > state.ema20;
            },

            isBelowEMA(price) {
                return state.ema20 && price < state.ema20;
            }
        };

        // ==================== PATTERN DETECTION ENGINE ====================
        const patternDetectionEngine = {
            analyze(completedCandle) {
                if (state.candles.length < 15) return;
                
                const prevCandle = state.candles[state.candles.length - 2];
                const recentCandles = state.candles.slice(-10);
                
                // Check for Elephant candle (previous candle)
                const avgBody = candleBuilder.getAverageBody(10);
                const isElephant = prevCandle.bodySize > (avgBody * 1.5);
                
                if (!isElephant) return;
                
                // Determine if previous candle was elephant
                const wasBullishElephant = prevCandle.direction === 'bullish' && isElephant;
                const wasBearishElephant = prevCandle.direction === 'bearish' && isElephant;
                
                // Check exhaustion (at least 3 candles same direction before elephant)
                const exhaustionMet = this.checkExhaustion(prevCandle.direction);
                
                // Check for reversal patterns
                let signal = null;
                
                if (wasBearishElephant && this.isBull180(completedCandle, prevCandle)) {
                    signal = {
                        type: 'BULL_180',
                        direction: 'Rise',
                        elephant: prevCandle,
                        reversal: completedCandle,
                        exhaustion: exhaustionMet
                    };
                } else if (wasBullishElephant && this.isBear180(completedCandle, prevCandle)) {
                    signal = {
                        type: 'BEAR_180',
                        direction: 'Fall',
                        elephant: prevCandle,
                        reversal: completedCandle,
                        exhaustion: exhaustionMet
                    };
                }
                
                if (signal) {
                    this.processSignal(signal);
                }
            },

            checkExhaustion(elephantDirection) {
                if (state.candles.length < 5) return false;
                const prior = state.candles.slice(-5, -2); // 3 candles before elephant
                return prior.every(c => c.direction === elephantDirection);
            },

            isBull180(current, previous) {
                return current.direction === 'bullish' && 
                       current.close > previous.high &&
                       current.bodySize >= (previous.bodySize * 0.8);
            },

            isBear180(current, previous) {
                return current.direction === 'bearish' && 
                       current.close < previous.low &&
                       current.bodySize >= (previous.bodySize * 0.8);
            },

            processSignal(signal) {
                // Calculate confidence score
                const confidence = confidenceScoringEngine.calculate(signal);
                
                // Update UI
                dashboardUpdater.updateSignal(signal, confidence);
                
                // Log detection
                logger.log(`EMCO 180 ${signal.type} detected (Confidence: ${confidence}%)`, 'info');
                
                // Check if we should trade
                if (confidence >= CONFIG.MIN_CONFIDENCE) {
                    this.evaluateTradeEntry(signal, confidence);
                }
                
                // Store for adaptive learning
                state.signalHistory.push({
                    ...signal,
                    confidence,
                    timestamp: Date.now(),
                    result: null
                });
            },

            evaluateTradeEntry(signal, confidence) {
                // Check trade limits
                if (!riskManager.canTrade()) return;
                
                // Check trend filter
                const price = state.lastTick?.quote;
                if (!price || !state.ema20) return;
                
                const aboveEMA = emaCalculator.isAboveEMA(price);
                const belowEMA = emaCalculator.isBelowEMA(price);
                
                if (signal.type === 'BULL_180' && !aboveEMA) {
                    logger.log('Bull signal rejected - price below EMA20', 'warning');
                    return;
                }
                
                if (signal.type === 'BEAR_180' && !belowEMA) {
                    logger.log('Bear signal rejected - price above EMA20', 'warning');
                    return;
                }
                
                // Execute trade at open of next candle
                logger.log(`Preparing ${signal.direction} trade entry...`, 'success');
                tradeExecutionModule.prepareEntry(signal, confidence);
            }
        };

        // ==================== CONFIDENCE SCORING ENGINE ====================
        const confidenceScoringEngine = {
            calculate(signal) {
                let score = 0;
                const weights = state.adaptiveWeights;
                
                // 1. Elephant detected (base)
                score += weights.elephant;
                
                // 2. Full engulf check
                const isFullEngulf = signal.type === 'BULL_180' ? 
                    signal.reversal.close > signal.elephant.high :
                    signal.reversal.close < signal.elephant.low;
                if (isFullEngulf) score += weights.engulf;
                
                // 3. Trend alignment
                const price = state.lastTick?.quote;
                if (price && state.ema20) {
                    if (signal.type === 'BULL_180' && price > state.ema20) score += weights.trend;
                    if (signal.type === 'BEAR_180' && price < state.ema20) score += weights.trend;
                }
                
                // 4. Exhaustion
                if (signal.exhaustion) score += weights.exhaustion;
                
                // 5. Strong reversal (80% of elephant)
                const strengthRatio = signal.reversal.bodySize / signal.elephant.bodySize;
                if (strengthRatio >= 0.8) score += weights.strength;
                
                // 6. EMA reaction (price near EMA)
                if (price && state.ema20) {
                    const emaDistance = Math.abs(price - state.ema20) / price;
                    if (emaDistance < 0.001) score += weights.ema; // Within 0.1%
                }
                
                return Math.min(100, Math.round(score));
            },

            // Adaptive learning - adjust weights based on performance
            adaptWeights(tradeResult) {
                const recentSignals = state.signalHistory.slice(-20);
                const winningSignals = recentSignals.filter(s => s.result === 'win');
                
                if (winningSignals.length < 5) return; // Need more data
                
                // Analyze which factors contributed to wins
                const avgConfidence = winningSignals.reduce((a, s) => a + s.confidence, 0) / winningSignals.length;
                
                // Slightly adjust weights based on performance
                if (tradeResult === 'win') {
                    // Reinforce current weights slightly
                    Object.keys(state.adaptiveWeights).forEach(key => {
                        state.adaptiveWeights[key] = Math.min(25, 
                            state.adaptiveWeights[key] * (1 + CONFIG.ADAPTIVE_LEARNING_RATE)
                        );
                    });
                } else {
                    // Reduce weights slightly on loss
                    Object.keys(state.adaptiveWeights).forEach(key => {
                        state.adaptiveWeights[key] = Math.max(5,
                            state.adaptiveWeights[key] * (1 - CONFIG.ADAPTIVE_LEARNING_RATE * 0.5)
                        );
                    });
                }
                
                // Normalize to ensure total stays around 100
                const total = Object.values(state.adaptiveWeights).reduce((a, b) => a + b, 0);
                const factor = 100 / total;
                Object.keys(state.adaptiveWeights).forEach(key => {
                    state.adaptiveWeights[key] = Math.round(state.adaptiveWeights[key] * factor);
                });
            }
        };

        // ==================== TRADE EXECUTION MODULE ====================
        const tradeExecutionModule = {
            async prepareEntry(signal, confidence) {
                // Calculate stake
                const stake = riskManager.calculateStake();
                if (stake <= 0) {
                    logger.log('Invalid stake calculated', 'error');
                    return;
                }
                
                const timeframe = parseInt(document.getElementById('timeframeSelect').value);
                
                if (state.simulationMode) {
                    // Simulate trade
                    this.simulateTrade(signal, stake, timeframe, confidence);
                    return;
                }
                
                // Real trade execution
                const proposalReq = {
                    proposal: 1,
                    amount: stake,
                    basis: 'stake',
                    contract_type: signal.direction === 'Rise' ? 'CALL' : 'PUT',
                    currency: state.currency,
                    duration: timeframe / 60,
                    duration_unit: 'm',
                    symbol: document.getElementById('marketSelect').value,
                    req_id: Date.now()
                };
                
                state.pendingProposal = {
                    ...proposalReq,
                    signal,
                    confidence,
                    stake
                };
                
                connectionModule.send(proposalReq);
                logger.log(`Proposal requested: ${signal.direction} $${stake}`, 'info');
            },

            handleProposal(proposal) {
                if (!state.pendingProposal) return;
                
                logger.log(`Proposal received: ${proposal.id}`, 'info');
                
                // Execute buy
                connectionModule.send({
                    buy: proposal.id,
                    price: state.pendingProposal.stake,
                    req_id: Date.now()
                });
            },

            handleBuyConfirmation(buy) {
                if (!state.pendingProposal) return;
                
                const contract = {
                    contract_id: buy.contract_id,
                    signal: state.pendingProposal.signal,
                    confidence: state.pendingProposal.confidence,
                    stake: state.pendingProposal.stake,
                    entryTime: Date.now(),
                    entryPrice: state.lastTick?.quote,
                    direction: state.pendingProposal.signal.direction
                };
                
                state.openContracts.push(contract);
                state.pendingProposal = null;
                
                logger.log(`Trade executed: ${contract.direction} (ID: ${contract.contract_id})`, 'success');
                dashboardUpdater.addTrade(contract);
                
                // Update stats
                state.dailyStats.tradesTaken++;
                state.dailyStats.lastTradeTime = Date.now();
                state.dailyStats.candlesSinceLastTrade = 0;
                
                // Subscribe to contract updates
                connectionModule.send({
                    proposal_open_contract: 1,
                    contract_id: contract.contract_id,
                    subscribe: 1
                });
            },

            handleContractUpdate(contract) {
                if (contract.is_expired || contract.is_sold) {
                    this.closeContract(contract);
                }
            },

            closeContract(contractUpdate) {
                const contract = state.openContracts.find(c => c.contract_id === contractUpdate.contract_id);
                if (!contract) return;
                
                const profit = contractUpdate.profit;
                const result = profit > 0 ? 'win' : 'loss';
                
                // Update trade record
                contract.result = result;
                contract.profit = profit;
                contract.exitPrice = contractUpdate.exit_tick;
                contract.exitTime = Date.now();
                
                // Move to history
                state.tradeHistory.unshift(contract);
                if (state.tradeHistory.length > 100) state.tradeHistory.pop();
                
                // Remove from open
                state.openContracts = state.openContracts.filter(c => c.contract_id !== contract.contract_id);
                
                // Update daily stats
                state.dailyStats.currentProfit += profit;
                if (result === 'loss') {
                    state.dailyStats.consecutiveLosses++;
                    if (state.dailyStats.consecutiveLosses >= CONFIG.PAUSE_AFTER_CONSECUTIVE_LOSSES) {
                        this.triggerPause();
                    }
                } else {
                    state.dailyStats.consecutiveLosses = 0;
                }
                
                // Update market quality
                this.updateMarketQuality(result);
                
                // Adaptive learning
                confidenceScoringEngine.adaptWeights(result);
                
                // Update signal history
                const signal = state.signalHistory.find(s => 
                    Math.abs(s.timestamp - contract.entryTime) < 5000
                );
                if (signal) signal.result = result;
                
                // Check limits
                riskManager.checkLimits();
                
                // Update UI
                dashboardUpdater.updateTradeResult(contract, result);
                dashboardUpdater.updateStatistics();
                
                logger.log(`Trade closed: ${result.toUpperCase()} P/L: $${profit.toFixed(2)}`, 
                    result === 'win' ? 'success' : 'error');
            },

            triggerPause() {
                state.dailyStats.isPaused = true;
                state.dailyStats.pauseEndCandle = state.dailyStats.candlesSinceLastTrade + CONFIG.RESUME_AFTER_CANDLES;
                logger.log(`Trading paused after ${CONFIG.PAUSE_AFTER_CONSECUTIVE_LOSSES} consecutive losses`, 'warning');
            },

            updateMarketQuality(result) {
                const symbol = document.getElementById('marketSelect').value;
                const quality = state.marketQuality[symbol];
                if (!quality) return;
                
                quality.trades++;
                if (result === 'win') quality.wins++;
                quality.winRate = (quality.wins / quality.trades) * 100;
                
                dashboardUpdater.updateMarketQuality();
            },

            simulateTrade(signal, stake, duration, confidence) {
                // Simulate execution delay
                setTimeout(() => {
                    const contract = {
                        contract_id: `SIM_${Date.now()}`,
                        signal,
                        confidence,
                        stake,
                        entryTime: Date.now(),
                        entryPrice: state.lastTick?.quote || signal.reversal.close,
                        direction: signal.direction,
                        isSimulation: true
                    };
                    
                    state.openContracts.push(contract);
                    state.dailyStats.tradesTaken++;
                    state.dailyStats.lastTradeTime = Date.now();
                    state.dailyStats.candlesSinceLastTrade = 0;
                    
                    logger.log(`[SIM] Trade executed: ${contract.direction} $${stake}`, 'success');
                    dashboardUpdater.addTrade(contract);
                    
                    // Simulate result after duration
                    setTimeout(() => {
                        this.simulateResult(contract);
                    }, duration * 1000);
                }, 500);
            },

            simulateResult(contract) {
                // Simulate realistic outcome based on confidence and randomness
                // Higher confidence = higher win probability, but not guaranteed
                const baseWinRate = 0.55; // Base 55% win rate
                const confidenceBoost = (contract.confidence - 70) / 100 * 0.2; // Up to 20% boost
                const winProbability = Math.min(0.85, baseWinRate + confidenceBoost);
                
                const isWin = Math.random() < winProbability;
                const payout = 0.94; // 94% payout rate
                const profit = isWin ? contract.stake * payout : -contract.stake;
                const result = isWin ? 'win' : 'loss';
                
                contract.result = result;
                contract.profit = profit;
                contract.exitPrice = state.lastTick?.quote || contract.entryPrice;
                contract.exitTime = Date.now();
                
                state.tradeHistory.unshift(contract);
                if (state.tradeHistory.length > 100) state.tradeHistory.pop();
                
                state.openContracts = state.openContracts.filter(c => c.contract_id !== contract.contract_id);
                
                state.dailyStats.currentProfit += profit;
                if (result === 'loss') {
                    state.dailyStats.consecutiveLosses++;
                    if (state.dailyStats.consecutiveLosses >= CONFIG.PAUSE_AFTER_CONSECUTIVE_LOSSES) {
                        this.triggerPause();
                    }
                } else {
                    state.dailyStats.consecutiveLosses = 0;
                }
                
                riskManager.checkLimits();
                dashboardUpdater.updateTradeResult(contract, result);
                dashboardUpdater.updateStatistics();
                
                logger.log(`[SIM] Trade closed: ${result.toUpperCase()} P/L: $${profit.toFixed(2)}`, 
                    result === 'win' ? 'success' : 'error');
            }
        };

        // ==================== RISK MANAGER MODULE ====================
        const riskManager = {
            canTrade() {
                // Check if trading is active
                if (!state.isTrading) return false;
                
                // Check pause status
                if (state.dailyStats.isPaused) {
                    logger.log('Trading paused - waiting for cooldown', 'warning');
                    return false;
                }
                
                // Check max trades per hour
                const recentTrades = state.tradeHistory.filter(t => 
                    Date.now() - t.entryTime < 3600000
                ).length;
                if (recentTrades >= CONFIG.MAX_TRADES_PER_HOUR) {
                    logger.log('Max trades per hour reached', 'warning');
                    return false;
                }
                
                // Check minimum candles between trades
                if (state.dailyStats.candlesSinceLastTrade < CONFIG.MIN_CANDLES_BETWEEN_TRADES) {
                    logger.log('Minimum candle distance not met', 'warning');
                    return false;
                }
                
                // Check daily limits
                if (this.checkLimits()) return false;
                
                return true;
            },

            calculateStake() {
                const riskPercent = parseFloat(document.getElementById('riskPercent').value) || 2;
                const stake = (state.balance * (riskPercent / 100));
                return Math.max(0.35, Math.min(stake, state.balance * 0.05)); // Min 0.35, max 5% of balance
            },

            checkLimits() {
                const profitTarget = parseFloat(document.getElementById('profitTarget').value) || 10;
                const lossLimit = parseFloat(document.getElementById('lossLimit').value) || 6;
                
                const profitPercent = (state.dailyStats.currentProfit / state.dailyStats.startBalance) * 100;
                
                // Check profit target
                if (profitPercent >= profitTarget) {
                    logger.log(`Daily profit target reached: +${profitPercent.toFixed(2)}%`, 'success');
                    botController.stopTrading();
                    return true;
                }
                
                // Check loss limit
                if (profitPercent <= -lossLimit) {
                    logger.log(`Daily loss limit reached: ${profitPercent.toFixed(2)}%`, 'error');
                    botController.stopTrading();
                    return true;
                }
                
                // Check minimum balance
                if (state.balance < 1) {
                    logger.log('Insufficient balance', 'error');
                    botController.stopTrading();
                    return true;
                }
                
                return false;
            },

            resetDailyStats() {
                state.dailyStats = {
                    startBalance: state.balance,
                    currentProfit: 0,
                    tradesTaken: 0,
                    lastTradeTime: null,
                    candlesSinceLastTrade: 0,
                    consecutiveLosses: 0,
                    isPaused: false,
                    pauseEndCandle: 0
                };
            }
        };

        // ==================== DASHBOARD UPDATER MODULE ====================
        const dashboardUpdater = {
            updateAccountInfo() {
                document.getElementById('balanceDisplay').textContent = state.balance.toFixed(2);
                document.getElementById('currencyDisplay').textContent = state.currency;
            },

            updateBalance() {
                document.getElementById('balanceDisplay').textContent = state.balance.toFixed(2);
                
                // Update daily P/L display
                const pl = state.dailyStats.currentProfit;
                const plElement = document.getElementById('dailyPL');
                plElement.textContent = (pl >= 0 ? '+' : '') + pl.toFixed(2);
                plElement.className = 'stat-value ' + (pl >= 0 ? 'positive' : 'negative');
                
                // Update progress bar
                const profitTarget = parseFloat(document.getElementById('profitTarget').value) || 10;
                const lossLimit = parseFloat(document.getElementById('lossLimit').value) || 6;
                const totalRange = profitTarget + lossLimit;
                const currentPercent = ((pl / state.dailyStats.startBalance) * 100 + lossLimit) / totalRange * 100;
                document.getElementById('dailyProgress').style.width = 
                    Math.max(0, Math.min(100, currentPercent)) + '%';
            },

            updateCandleInfo(candle) {
                // Could add real-time candle display here
            },

            updateSignal(signal, confidence) {
                const display = document.getElementById('signalDisplay');
                const direction = document.getElementById('signalDirection');
                const details = document.getElementById('signalDetails');
                const fill = document.getElementById('confidenceFill');
                
                display.className = 'signal-display ' + (signal.type === 'BULL_180' ? 'bull' : 'bear');
                direction.innerHTML = `<span class="${signal.type === 'BULL_180' ? 'bull' : 'bear'}">
                    ${signal.type} DETECTED
                </span>`;
                direction.className = 'signal-direction ' + (signal.type === 'BULL_180' ? 'bull' : 'bear');
                
                details.innerHTML = `
                    Elephant: ${signal.elephant.direction} | 
                    Reversal: ${signal.reversal.direction} | 
                    Exhaustion: ${signal.exhaustion ? 'Yes' : 'No'}
                `;
                
                fill.style.width = confidence + '%';
                fill.textContent = confidence + '% CONFIDENCE';
            },

            addTrade(contract) {
                const tbody = document.getElementById('tradesTableBody');
                
                // Clear "no trades" message if exists
                if (tbody.children.length === 1 && tbody.children[0].textContent.includes('No trades')) {
                    tbody.innerHTML = '';
                }
                
                const row = document.createElement('tr');
                row.id = `trade_${contract.contract_id}`;
                row.innerHTML = `
                    <td>${new Date(contract.entryTime).toLocaleTimeString()}</td>
                    <td>${contract.direction}</td>
                    <td>Open</td>
                    <td>--</td>
                `;
                
                tbody.insertBefore(row, tbody.firstChild);
                
                // Keep only last 20 visible
                while (tbody.children.length > 20) {
                    tbody.removeChild(tbody.lastChild);
                }
            },

            updateTradeResult(contract, result) {
                const row = document.getElementById(`trade_${contract.contract_id}`);
                if (!row) return;
                
                row.innerHTML = `
                    <td>${new Date(contract.entryTime).toLocaleTimeString()}</td>
                    <td>${contract.direction}</td>
                    <td class="${result}">${result.toUpperCase()}</td>
                    <td class="${result}">${contract.profit >= 0 ? '+' : ''}${contract.profit.toFixed(2)}</td>
                `;
            },

            updateStatistics() {
                const total = state.tradeHistory.length;
                const wins = state.tradeHistory.filter(t => t.result === 'win').length;
                const losses = total - wins;
                const winRate = total > 0 ? (wins / total * 100).toFixed(1) : 0;
                const netProfit = state.tradeHistory.reduce((sum, t) => sum + t.profit, 0);
                
                document.getElementById('totalTrades').textContent = total;
                document.getElementById('totalWins').textContent = wins;
                document.getElementById('totalLosses').textContent = losses;
                document.getElementById('winRate').textContent = winRate + '%';
                
                const profitElement = document.getElementById('netProfit');
                profitElement.textContent = (netProfit >= 0 ? '+' : '') + netProfit.toFixed(2);
                profitElement.className = 'stat-value ' + (netProfit >= 0 ? 'positive' : 'negative');
                
                this.updateBalance();
            },

            updateMarketQuality() {
                const container = document.getElementById('marketQuality');
                const currentSymbol = document.getElementById('marketSelect').value;
                
                let html = '';
                Object.entries(state.marketQuality).forEach(([symbol, data]) => {
                    const isCurrent = symbol === currentSymbol;
                    const isGood = data.winRate >= 50;
                    html += `<span class="quality-badge ${isGood ? 'good' : 'bad'} ${isCurrent ? 'current' : ''}">
                        ${CONFIG.MARKET_SYMBOLS[symbol]}: ${data.winRate.toFixed(1)}%
                    </span>`;
                });
                
                container.innerHTML = html || '<span class="quality-badge">Collecting data...</span>';
            },

            resetSignalDisplay() {
                const display = document.getElementById('signalDisplay');
                display.className = 'signal-display neutral';
                document.getElementById('signalDirection').textContent = 'WAITING FOR SIGNAL';
                document.getElementById('signalDirection').className = 'signal-direction';
                document.getElementById('signalDetails').textContent = 'Bot ready to analyze market';
                document.getElementById('confidenceFill').style.width = '0%';
                document.getElementById('confidenceFill').textContent = '0%';
            }
        };

        // ==================== BOT CONTROLLER ====================
        const botController = {
            startTrading() {
                if (!state.isConnected) {
                    logger.log('Connect to API first', 'error');
                    return;
                }
                
                if (state.isTrading) {
                    logger.log('Already trading', 'warning');
                    return;
                }
                
                state.simulationMode = document.getElementById('simulationMode').checked;
                state.isTrading = true;
                
                // Reset daily stats if starting fresh
                if (state.dailyStats.tradesTaken === 0) {
                    riskManager.resetDailyStats();
                }
                
                // Subscribe to market
                marketDataModule.subscribeToMarket();
                
                // Update UI
                document.getElementById('startBtn').disabled = true;
                document.getElementById('stopBtn').disabled = false;
                document.getElementById('marketSelect').disabled = true;
                document.getElementById('timeframeSelect').disabled = true;
                
                logger.log(`Trading started ${state.simulationMode ? '[SIMULATION]' : '[LIVE]'}`, 'success');
                logger.log(`Market: ${CONFIG.MARKET_SYMBOLS[document.getElementById('marketSelect').value]}`, 'info');
            },

            stopTrading() {
                state.isTrading = false;
                
                // Unsubscribe from ticks
                if (state.ws) {
                    connectionModule.send({ forget_all: 'ticks' });
                }
                
                // Update UI
                document.getElementById('startBtn').disabled = false;
                document.getElementById('stopBtn').disabled = true;
                document.getElementById('marketSelect').disabled = false;
                document.getElementById('timeframeSelect').disabled = false;
                
                dashboardUpdater.resetSignalDisplay();
                logger.log('Trading stopped', 'warning');
            }
        };

        // ==================== EVENT LISTENERS ====================
        document.getElementById('marketSelect').addEventListener('change', () => {
            marketDataModule.changeMarket();
        });

        document.getElementById('timeframeSelect').addEventListener('change', () => {
            if (state.isTrading) {
                logger.log('Stop trading before changing timeframe', 'warning');
                return;
            }
            state.candles = [];
            state.currentCandle = null;
        });

        // Prevent accidental close while trading
        window.addEventListener('beforeunload', (e) => {
            if (state.isTrading) {
                e.preventDefault();
                e.returnValue = 'Trading is active. Are you sure you want to leave?';
            }
        });

        // Initialize
        logger.log('EMCO 180 Precision Bot initialized', 'info');
        logger.log('Ready to connect', 'info');
    </script>
</body>
</html>
